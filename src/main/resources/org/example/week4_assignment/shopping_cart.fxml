<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>

<VBox fx:id="rootVBox"
      alignment="CENTER"
      spacing="10"
      xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="org.example.week3_assignment.ShoppingCartController">

    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <Label fx:id="titleLabel" text="Shopping Cart"/>

    <ComboBox fx:id="languageSelector" prefWidth="180"/>

    <Label fx:id="itemsLabel" text="Enter number of items:"/>
    <TextField fx:id="itemsField" prefWidth="200"/>

    <Button fx:id="enterButton" text="Enter"/>

    <Label fx:id="priceLabel" text="Enter price:" visible="false"/>
    <TextField fx:id="priceField" prefWidth="200" visible="false"/>

    <Label fx:id="quantityLabel" text="Enter quantity:" visible="false"/>
    <TextField fx:id="quantityField" prefWidth="200" visible="false"/>

    <Button fx:id="calculateButton" text="Calculate" visible="false"/>

    <Label fx:id="totalLabel" text=""/>
</VBox>